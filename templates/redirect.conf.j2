# {{ ansible_managed }}

server {
    listen {{ nginx_redirect_http_port }} default_server;
    listen [::]:{{ nginx_redirect_http_port }} default_server;
    server_name _;

    # acme.sh webroot challenge — must not redirect to HTTPS
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}
